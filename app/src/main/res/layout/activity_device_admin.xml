<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Device Admin Setup"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1976D2"
        android:layout_marginBottom="24dp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="4dp"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_device_admin_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Status"
                android:textSize="16sp"
                android:textColor="#333333"
                android:lineSpacingExtra="6dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btn_enable_device_admin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Enable Device Admin"
        android:textColor="#FFFFFF"
        android:background="#4CAF50"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_disable_device_admin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Disable Device Admin"
        android:textColor="#FFFFFF"
        android:background="#F44336" />

</LinearLayout>
